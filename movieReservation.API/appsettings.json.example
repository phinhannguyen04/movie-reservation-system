{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=moviereservation;Username=postgres;Password=<YOUR_POSTGRES_PASSWORD>"
  },
  "JwtSettings": {
    "SecretKey": "<YOUR_SECURE_JWT_SECRET_KEY_AT_LEAST_32_CHARS>",
    "Issuer": "MovieReservation.API",
    "Audience": "MovieReservation.Client",
    "ExpirationInMinutes": 1440
  }
}
